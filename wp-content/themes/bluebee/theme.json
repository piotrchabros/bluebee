{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"custom": true,
			"customGradient": true,
			"palette": [
				{ "slug": "cream",   "color": "#F7F4EF", "name": "Cream" },
				{ "slug": "white",   "color": "#FFFFFF",  "name": "White" },
				{ "slug": "black",   "color": "#0C0C0A",  "name": "Black" },
				{ "slug": "gray",    "color": "#6B6963",  "name": "Gray" },
				{ "slug": "border",  "color": "#E2DED8",  "name": "Border" },
				{ "slug": "blue",    "color": "#1B45E8",  "name": "Accent Blue" },
				{ "slug": "orange",  "color": "#F04A17",  "name": "Accent Orange" },
				{ "slug": "lime",    "color": "#CAFC00",  "name": "Accent Lime" },
				{ "slug": "surface", "color": "#FDFCFA",  "name": "Surface" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": true,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontFamilies": [
				{
					"fontFamily": "'Syne', sans-serif",
					"slug": "heading",
					"name": "Syne"
				},
				{
					"fontFamily": "'DM Sans', sans-serif",
					"slug": "body",
					"name": "DM Sans"
				}
			],
			"fontSizes": [
				{ "slug": "xs",   "size": "0.75rem",  "name": "XS",   "fluid": false },
				{ "slug": "sm",   "size": "0.875rem", "name": "SM",   "fluid": false },
				{ "slug": "base", "size": "1rem",     "name": "Base", "fluid": false },
				{ "slug": "lg",   "size": "1.125rem", "name": "LG",   "fluid": false },
				{ "slug": "xl",   "size": "1.25rem",  "name": "XL",   "fluid": false },
				{ "slug": "2xl",  "size": "1.5rem",   "name": "2XL",  "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "3xl",  "size": "1.875rem", "name": "3XL",  "fluid": { "min": "1.5rem",  "max": "1.875rem" } },
				{ "slug": "4xl",  "size": "2.5rem",   "name": "4XL",  "fluid": { "min": "1.875rem","max": "2.5rem" } },
				{ "slug": "5xl",  "size": "3.5rem",   "name": "5XL",  "fluid": { "min": "2.5rem",  "max": "3.5rem" } },
				{ "slug": "6xl",  "size": "5rem",     "name": "6XL",  "fluid": { "min": "3rem",    "max": "5rem" } },
				{ "slug": "7xl",  "size": "7rem",     "name": "7XL",  "fluid": { "min": "4rem",    "max": "7rem" } },
				{ "slug": "8xl",  "size": "9rem",     "name": "8XL",  "fluid": { "min": "5rem",    "max": "9rem" } }
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"units": ["px", "%", "em", "rem", "vh", "vw"],
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem",  "name": "1" },
				{ "slug": "20", "size": "1rem",    "name": "2" },
				{ "slug": "30", "size": "1.5rem",  "name": "3" },
				{ "slug": "40", "size": "2rem",    "name": "4" },
				{ "slug": "50", "size": "3rem",    "name": "5" },
				{ "slug": "60", "size": "4rem",    "name": "6" },
				{ "slug": "70", "size": "6rem",    "name": "7" },
				{ "slug": "80", "size": "8rem",    "name": "8" },
				{ "slug": "90", "size": "10rem",   "name": "9" }
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1280px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{ "slug": "sm",  "shadow": "0 1px 3px rgba(12,12,10,0.08)",             "name": "Small" },
				{ "slug": "md",  "shadow": "0 4px 16px rgba(12,12,10,0.1)",             "name": "Medium" },
				{ "slug": "lg",  "shadow": "0 16px 48px rgba(12,12,10,0.12)",           "name": "Large" },
				{ "slug": "xl",  "shadow": "0 32px 80px rgba(12,12,10,0.15)",           "name": "XL" },
				{ "slug": "blue","shadow": "0 8px 32px rgba(27,69,232,0.25)",           "name": "Blue" }
			]
		},
		"custom": {
			"fontWeight": {
				"light":      "300",
				"regular":    "400",
				"medium":     "500",
				"semiBold":   "600",
				"bold":       "700",
				"extraBold":  "800"
			},
			"lineHeight": {
				"tight":   "1",
				"snug":    "1.15",
				"normal":  "1.5",
				"relaxed": "1.7"
			},
			"letterSpacing": {
				"tight":  "-0.03em",
				"snug":   "-0.02em",
				"normal": "0",
				"wide":   "0.05em",
				"wider":  "0.1em",
				"widest": "0.15em"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--cream)",
			"text":       "var(--wp--preset--color--black)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize":   "var(--wp--preset--font-size--base)",
			"lineHeight": "var(--wp--custom--line-height--normal)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "700",
					"lineHeight":    "var(--wp--custom--line-height--tight)",
					"letterSpacing": "var(--wp--custom--letter-spacing--snug)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "800",
					"fontSize":      "clamp(3rem, 8vw, 7rem)",
					"lineHeight":    "0.95",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "700",
					"fontSize":      "clamp(2rem, 5vw, 4rem)",
					"letterSpacing": "-0.025em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "600",
					"fontSize":      "clamp(1.5rem, 3vw, 2rem)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "600",
					"fontSize":   "1.25rem"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--blue)" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--orange)" },
					"typography": { "textDecoration": "none" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--black)",
					"text":       "var(--wp--preset--color--cream)"
				},
				"border": {
					"radius": "0px"
				},
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "600",
					"fontSize":      "0.8rem",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top":    "1rem",
						"bottom": "1rem",
						"left":   "2.25rem",
						"right":  "2.25rem"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"color": { "text": "var(--wp--preset--color--black)" },
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontWeight":    "800",
					"fontSize":      "1.1rem",
					"letterSpacing": "-0.02em",
					"lineHeight":    "1"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--heading)",
					"fontSize":      "0.75rem",
					"fontWeight":    "600",
					"letterSpacing": "0.1em",
					"textTransform": "uppercase"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)"
				}
			},
			"core/pullquote": {
				"border": {
					"style": "solid",
					"width": "2px 0",
					"color": "var(--wp--preset--color--border)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize":   "var(--wp--preset--font-size--3xl)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--black)"
				}
			},
			"core/quote": {
				"border": {
					"width": "0 0 0 3px",
					"color": "var(--wp--preset--color--blue)",
					"style": "solid"
				},
				"spacing": {
					"padding": { "left": "1.5rem" }
				}
			},
			"core/separator": {
				"color": { "text": "var(--wp--preset--color--border)" },
				"border": { "color": "var(--wp--preset--color--border)" }
			},
			"core/code": {
				"color": { "background": "#F0EDE8" },
				"border": { "radius": "4px" },
				"typography": { "fontSize": "0.875rem" },
				"spacing": {
					"padding": { "top": "1rem", "bottom": "1rem", "left": "1.25rem", "right": "1.25rem" }
				}
			}
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header", "title": "Header" },
		{ "area": "footer", "name": "footer", "title": "Footer" }
	],
	"customTemplates": [
		{ "name": "page-no-hero",   "title": "Page: No Hero",        "postTypes": ["page"] },
		{ "name": "page-full-width","title": "Page: Full Width",     "postTypes": ["page"] },
		{ "name": "single-work",    "title": "Single: Portfolio Work","postTypes": ["bb_work"] }
	]
}
